# Application
APP_NAME=Inventory Sync Service
APP_VERSION=0.1.0
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inventory
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_pass

# Cache
REDIS_HOST=redis
REDIS_PORT=6379

# Messaging
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_INVENTORY_EVENTS=inventory.events
KAFKA_TOPIC_INVENTORY_UPDATES=inventory_updates

# Health checks
ENABLE_DEPENDENCY_HEALTH_CHECKS=false
